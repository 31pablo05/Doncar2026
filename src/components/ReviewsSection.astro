---
import { reviews } from '../data/reviews';
---

<section class="py-20 px-4" style="background: #0f0f1a;">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="font-syne font-black text-2xl sm:text-3xl md:text-4xl lg:text-5xl text-white mb-4">
        Lo que dicen <span style="color: #00E5FF;">nuestros clientes</span>
      </h2>
      <div class="flex items-center justify-center gap-3 mt-4">
        <span class="text-4xl font-black" style="color: #00E5FF;">4.8</span>
        <div>
          <div class="text-xl">⭐⭐⭐⭐⭐</div>
          <div class="text-white/50 text-sm">en Google Reviews</div>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {reviews.map(review => (
        <div class="p-6 rounded-2xl border transition-all duration-300 hover:scale-[1.02]"
             style="background: #0f0f1a; border-color: rgba(255,255,255,0.06);"
             onmouseover="this.style.borderColor='rgba(0,229,255,0.22)'"
             onmouseout="this.style.borderColor='rgba(255,255,255,0.06)'">
          <div class="flex gap-1 mb-4">
            {Array.from({ length: review.rating }).map(() => (
              <span style="color: #00E5FF;">★</span>
            ))}
          </div>

          <p class="text-white/70 text-sm leading-relaxed mb-6">"{review.comment}"</p>

          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full flex items-center justify-center font-bold text-sm"
                 style="background: linear-gradient(135deg, #00E5FF, #B44FFF); color: #070710;">
              {review.avatar}
            </div>
            <div>
              <div class="font-semibold text-white text-sm">{review.name}</div>
              <div class="text-white/40 text-xs">{review.date}</div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="text-center mt-10">
      <a href="https://www.google.com/search?q=cafe+doncar+trelew+rese%C3%B1as"
         target="_blank"
         class="inline-flex items-center gap-2 px-6 py-3 rounded-xl font-medium border transition-all hover:scale-105"
         style="border-color: rgba(0,229,255,0.3); color: #00E5FF; background: rgba(0,229,255,0.06);">
        Ver todas las reseñas en Google →
      </a>
    </div>
  </div>
</section>
