---
import { siteConfig } from '../data/siteConfig';

const navLinks = [
  { href: '#inicio',   label: 'Inicio',    emoji: '🏠' },
  { href: '#menu',     label: 'Menú',      emoji: '🍔' },
  { href: '#nosotros', label: 'Nosotros',  emoji: '👨‍🍳' },
  { href: '#horarios', label: 'Horarios',  emoji: '🕐' },
  { href: '#resenas',  label: 'Reseñas',  emoji: '⭐' },
];
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
  style="background: rgba(10,10,10,0.85); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); border-bottom: 1px solid rgba(255,255,255,0.06);">

  <!-- Barra de estado abierto/cerrado -->
  <div id="status-bar" class="hidden text-center text-xs py-1.5 font-medium tracking-wide transition-all"></div>

  <!-- ===== BARRA PRINCIPAL ===== -->
  <div class="max-w-7xl mx-auto px-5 flex items-center justify-between h-[68px]">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 group flex-shrink-0">
      <img
        src="/images/logo1comb.svg"
        alt="Café Doncar Delicias"
        class="h-24 w-auto group-hover:scale-105 transition-transform duration-200"
        style="filter: drop-shadow(0 0 8px rgba(0,229,255,0.3));"
      />
    </a>

    <!-- Nav Desktop -->
    <nav class="hidden md:flex items-center gap-1">
      {navLinks.map(link => (
        <a href={link.href} class="nav-link relative px-4 py-2 rounded-lg text-sm font-medium text-white/60 transition-all duration-200 hover:text-white group">
          <span class="relative z-10">{link.label}</span>
          <span class="nav-underline absolute bottom-0 left-1/2 -translate-x-1/2 h-[2px] w-0 rounded-full transition-all duration-300 group-hover:w-5"
                style="background: linear-gradient(90deg, #00E5FF, #B44FFF);"></span>
          <span class="absolute inset-0 rounded-lg opacity-0 group-hover:opacity-100 transition-opacity duration-200"
                style="background: rgba(0,229,255,0.05);"></span>
        </a>
      ))}
    </nav>

    <!-- Acciones: hamburger + carrito -->
    <div class="flex items-center gap-3">

      <!-- Hamburger (solo mobile) -->
      <button
        id="mobile-menu-btn"
        class="md:hidden flex flex-col items-center justify-center gap-1.5 w-10 h-10 rounded-xl transition-all duration-200"
        style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.08);"
        aria-label="Abrir menú"
      >
        <span class="hamburger-bar block w-5 h-[1.5px] bg-white/70 rounded-full transition-all duration-300 origin-center"></span>
        <span class="hamburger-bar block w-4 h-[1.5px] bg-white/50 rounded-full transition-all duration-300"></span>
        <span class="hamburger-bar block w-5 h-[1.5px] bg-white/70 rounded-full transition-all duration-300 origin-center"></span>
      </button>

      <!-- Botón carrito -->
      <button
        id="cart-btn"
        onclick="document.dispatchEvent(new CustomEvent('cart:open'))"
        class="cart-btn relative flex items-center gap-2 px-4 py-2.5 rounded-xl text-[#070710] font-bold text-sm transition-all duration-200 hover:scale-[1.04] active:scale-95"
        style="background: linear-gradient(135deg, #00E5FF, #B44FFF); box-shadow: 0 4px 14px rgba(0,229,255,0.25);"
      >
        <span class="text-base">🛒</span>
        <span class="hidden sm:inline">Pedido</span>
        <span
          id="cart-badge"
          class="hidden absolute -top-2 -right-2 w-5 h-5 bg-white text-black text-xs font-black rounded-full items-center justify-center"
          style="box-shadow: 0 2px 8px rgba(0,0,0,0.4);"
        ></span>
      </button>

    </div>
  </div>

  <!-- ===== PANEL MOBILE ===== -->
  <div
    id="mobile-nav"
    class="mobile-nav-panel md:hidden overflow-hidden"
    style="max-height: 0; transition: max-height 0.35s cubic-bezier(0.4,0,0.2,1), opacity 0.25s ease; opacity: 0; border-top: 1px solid rgba(255,255,255,0.05);"
  >
    <div style="background: rgba(8,8,8,0.98); backdrop-filter: blur(24px);">

      <!-- Links -->
      <nav class="px-5 pt-3 pb-2 space-y-1">
        {navLinks.map(link => (
          <a href={link.href}
             class="mobile-nav-link flex items-center justify-between px-4 py-3.5 rounded-xl text-white/70 font-medium text-sm transition-all duration-200 group"
             style="border: 1px solid transparent;">
            <span class="flex items-center gap-3">
              <span class="text-base">{link.emoji}</span>
              <span class="font-syne font-semibold text-[15px] group-hover:text-white transition-colors">{link.label}</span>
            </span>
            <span class="text-white/20 group-hover:text-orange-400 transition-colors text-xs">›</span>
          </a>
        ))}
      </nav>

      <!-- Footer del menú mobile -->
      <div class="px-5 pb-5 pt-3" style="border-top: 1px solid rgba(255,255,255,0.05);">
        <button
          onclick="document.dispatchEvent(new CustomEvent('cart:open'))"
          class="w-full flex items-center justify-center gap-2 py-3.5 rounded-xl text-[#070710] font-bold text-sm transition-all hover:scale-[1.02]"
          style="background: linear-gradient(135deg, #00E5FF, #B44FFF); box-shadow: 0 4px 16px rgba(0,229,255,0.2);"
        >
          🛒 Ver mi pedido
        </button>
        <p class="text-center text-white/25 text-xs mt-3 font-inter">Pellegrini 1624, Trelew · Pedidos por WhatsApp</p>
      </div>

    </div>
  </div>

</header>

<style>
  .nav-link:hover .nav-underline { width: 20px; }

  /* Hamburger animado al abrir */
  #mobile-menu-btn.is-open .hamburger-bar:nth-child(1) {
    transform: translateY(5px) rotate(45deg);
    width: 20px;
    opacity: 1;
  }
  #mobile-menu-btn.is-open .hamburger-bar:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  #mobile-menu-btn.is-open .hamburger-bar:nth-child(3) {
    transform: translateY(-5px) rotate(-45deg);
    width: 20px;
    opacity: 1;
  }

  /* Hover en links mobile */
  .mobile-nav-link:hover {
    background: rgba(255,77,0,0.07);
    border-color: rgba(255,77,0,0.18) !important;
    color: #ffffff;
  }

  /* Glow del botón carrito al hover */
  .cart-btn:hover {
    box-shadow: 0 6px 20px rgba(0,229,255,0.4);
  }

  /* Panel mobile open */
  .mobile-nav-panel.is-open {
    max-height: 520px !important;
    opacity: 1 !important;
  }
</style>

<script>
  /* ---- Badge del carrito ---- */
  document.addEventListener('cart:update', (e: any) => {
    const badge = document.getElementById('cart-badge');
    if (!badge) return;
    const count = e.detail?.count ?? 0;
    if (count > 0) {
      badge.textContent = String(count);
      badge.classList.remove('hidden');
      badge.classList.add('flex');
    } else {
      badge.classList.add('hidden');
      badge.classList.remove('flex');
    }
  });

  /* ---- Estado del local ---- */
  function checkBusinessStatus() {
    const bar = document.getElementById('status-bar');
    if (!bar) return;

    const now = new Date();
    const argStr = now.toLocaleString('en-US', { timeZone: 'America/Argentina/Buenos_Aires' });
    const argTime = new Date(argStr);
    const h = argTime.getHours();
    const m = argTime.getMinutes();
    const totalMin = h * 60 + m;

    const isOpen = totalMin >= 1080 || totalMin < 30;

    bar.textContent = isOpen
      ? '🟢  Abierto ahora — Pedidos por WhatsApp'
      : '🔴  Cerrado — Abrimos a las 18:00 hs';
    bar.style.background = isOpen ? 'rgba(0,229,255,0.12)' : 'rgba(228,64,251,0.12)';
    bar.style.color = isOpen ? '#00E5FF' : '#E040FB';
    bar.classList.remove('hidden');
  }

  checkBusinessStatus();

  /* ---- Menú mobile ---- */
  const btn    = document.getElementById('mobile-menu-btn');
  const panel  = document.getElementById('mobile-nav');

  btn?.addEventListener('click', () => {
    const isOpen = panel?.classList.contains('is-open');
    if (isOpen) {
      panel?.classList.remove('is-open');
      btn?.classList.remove('is-open');
    } else {
      panel?.classList.add('is-open');
      btn?.classList.add('is-open');
    }
  });

  document.querySelectorAll('.mobile-nav-link').forEach(link => {
    link.addEventListener('click', () => {
      panel?.classList.remove('is-open');
      btn?.classList.remove('is-open');
    });
  });

  /* ---- Header scroll shadow ---- */
  const header = document.getElementById('site-header');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 10) {
      header?.style.setProperty('box-shadow', '0 4px 30px rgba(0,0,0,0.6)');
    } else {
      header?.style.setProperty('box-shadow', 'none');
    }
  }, { passive: true });
</script>
