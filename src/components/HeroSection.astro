---
import { siteConfig } from '../data/siteConfig';
---

<section id="hero" class="relative min-h-svh flex items-center overflow-hidden" style="background: #070710;">

  <!-- ============================================================
       BACKGROUND MOBILE: foto del cartel del local
       Solo visible en < lg
  ============================================================ -->
  <div class="absolute inset-0 lg:hidden" aria-hidden="true">
    <img
      src="/images/hamburguesa bacon.jpg"
      alt=""
      class="w-full h-full object-cover object-center scale-105"
      fetchpriority="high"
    />
    <div class="absolute inset-0"
         style="background: linear-gradient(
           to bottom,
           rgba(7,7,16,0.15) 0%,
           rgba(7,7,16,0.5) 35%,
           rgba(7,7,16,0.92) 65%,
           #070710 100%
         );"></div>
    <div class="absolute inset-0"
         style="background: radial-gradient(ellipse at 15% 90%, rgba(0,229,255,0.07) 0%, transparent 55%);"></div>
  </div>

  <!-- ============================================================
       BACKGROUND DESKTOP: glows + grid sutil
       Solo visible en lg+
  ============================================================ -->
  <div class="absolute inset-0 hidden lg:block" aria-hidden="true">
    <!-- Glows de color -->
    <div class="absolute inset-0"
         style="background:
           radial-gradient(ellipse at 12% 55%, rgba(0,229,255,0.09) 0%, transparent 50%),
           radial-gradient(ellipse at 88% 35%, rgba(180,79,255,0.07) 0%, transparent 50%);"></div>
    <!-- Grid de líneas sutil -->
    <div class="absolute inset-0 opacity-[0.03]"
         style="background-image: linear-gradient(rgba(0,229,255,1) 1px, transparent 1px),
                                  linear-gradient(90deg, rgba(0,229,255,1) 1px, transparent 1px);
                background-size: 52px 52px;"></div>
  </div>

  <!-- ============================================================
       CONTENIDO PRINCIPAL
  ============================================================ -->
  <div class="relative z-10 w-full max-w-7xl mx-auto px-5 sm:px-8">
    <div class="lg:grid lg:grid-cols-[1fr_auto] lg:gap-20 lg:items-center min-h-svh lg:min-h-0 lg:py-20 flex flex-col justify-end pb-14 pt-24">

      <!-- ── COLUMNA IZQUIERDA: TEXTO ── -->
      <div class="animate-fade-in-up space-y-5 max-w-xl">

        <!-- Logo centrado en mobile, antes del pill -->
        <div class="flex justify-center mb-6 lg:hidden">
          <img
            src="/images/logo1comb.svg"
            alt="Café Doncar Delicias"
            class="w-[min(14rem,70vw)] sm:w-72 h-auto"
            style="filter: drop-shadow(0 0 20px rgba(0,229,255,0.3)) drop-shadow(0 0 40px rgba(180,79,255,0.15));"
            fetchpriority="high"
          />
        </div>

        <!-- Eyebrow pill -->
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-[11px] font-bold tracking-[0.14em] uppercase"
             style="background: rgba(0,229,255,0.07); border: 1px solid rgba(0,229,255,0.28); color: #00E5FF;">
          <span class="w-1.5 h-1.5 rounded-full animate-pulse flex-shrink-0" style="background: #00E5FF;"></span>
          Pellegrini 1624, Trelew · Abrimos 18:00 hs
        </div>

        <!-- Bloque de marca -->
        <div>
          <!-- MARCA 1: Café DONCAЯ -->
          <div class="flex items-baseline gap-2 leading-none mt-5 flex-wrap">
            <span class="font-syne font-black text-white/55 tracking-[0.1em] uppercase"
                  style="font-size: clamp(0.75rem, 2.5vw, 1.25rem);">Café</span>
            <span class="font-syne font-black text-white leading-none tracking-tight"
                  style="font-size: clamp(2rem, 9vw, 4.5rem); letter-spacing: -0.03em;">DONCAЯ</span>
          </div>

          <!-- Separador -->
          <div class="flex items-center gap-3 my-3">
            <div class="flex-1 h-px max-w-[160px]"
                 style="background: linear-gradient(to right, rgba(0,229,255,0.3), transparent);"></div>
            <span class="text-white/25 text-xs font-bold tracking-[0.2em] uppercase">&amp;</span>
            <div class="flex-1 h-px max-w-[160px]"
                 style="background: linear-gradient(to left, rgba(180,79,255,0.3), transparent);"></div>
          </div>

          <!-- MARCA 2: Delicias Cosas Ricas -->
          <div class="flex flex-col leading-none mb-5">
            <span class="font-syne font-black leading-none tracking-tight block">
              <span class="inline-block"
                    style="font-size: clamp(2rem, 6vw, 3.2rem);
                           background: linear-gradient(110deg, #00E5FF 0%, #B44FFF 55%, #E040FB 100%);
                           -webkit-background-clip: text; -webkit-text-fill-color: transparent;
                           background-clip: text;">
                Delicias
              </span>
            </span>
            <span class="font-syne font-black tracking-[0.18em] uppercase"
                  style="font-size: clamp(0.65rem, 1.8vw, 0.85rem); color: #E040FB; opacity: 0.85; margin-top: 2px;">
              Cosas Ricas
            </span>
          </div>
        </div>

        <!-- Tagline -->
        <p class="text-white/52 leading-relaxed max-w-sm"
           style="font-size: clamp(0.9rem, 2.2vw, 1.05rem);">
          De lo salado a lo dulce — todo en un solo lugar.<br/>
          Pedí por WhatsApp y recibí en tu puerta.
        </p>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-3 pt-2">
          <a href="#menu"
             class="flex items-center justify-center gap-2 px-7 py-4 rounded-2xl font-bold text-[#070710] text-base transition-all duration-300 hover:scale-[1.03] hover:brightness-110 active:scale-95"
             style="background: linear-gradient(135deg, #00E5FF, #B44FFF);
                    box-shadow: 0 6px 28px rgba(0,229,255,0.3);">
            Ver Menú <span style="font-size:1.2rem">🍔</span>
          </a>
          <a href={`https://wa.me/${siteConfig.whatsapp}?text=${encodeURIComponent('¡Hola! Quiero hacer un pedido 😊')}`}
             target="_blank" rel="noopener"
             class="flex items-center justify-center gap-2 px-7 py-4 rounded-2xl font-bold text-base transition-all duration-300 hover:scale-[1.03] active:scale-95"
             style="background: rgba(0,229,255,0.05);
                    border: 1px solid rgba(0,229,255,0.28);
                    color: #00E5FF;
                    backdrop-filter: blur(8px);">
            Pedir ahora <span style="font-size:1.2rem">💬</span>
          </a>
        </div>

        <!-- Stats -->
        <div class="flex items-stretch gap-3 sm:gap-6 pt-5 mt-1"
             style="border-top: 1px solid rgba(255,255,255,0.06);">
          <div>
            <div class="font-syne font-black text-xl" style="color: #00E5FF;">4.8★</div>
            <div class="text-white/35 text-[11px] mt-0.5 tracking-wide">Google Reviews</div>
          </div>
          <div class="w-px self-stretch" style="background: rgba(255,255,255,0.07);"></div>
          <div>
            <div class="font-syne font-black text-xl" style="color: #00E5FF;">+500</div>
            <div class="text-white/35 text-[11px] mt-0.5 tracking-wide">Pedidos/mes</div>
          </div>
          <div class="w-px self-stretch" style="background: rgba(255,255,255,0.07);"></div>
          <div>
            <div class="font-syne font-black text-xl" style="color: #00E5FF;">4 años</div>
            <div class="text-white/35 text-[11px] mt-0.5 tracking-wide">En Trelew</div>
          </div>
        </div>

      </div>

      <!-- ── COLUMNA DERECHA: VISUAL (solo lg+) ── -->
      <div class="hidden lg:block animate-slide-in-right flex-shrink-0">
        <div class="relative w-[500px] xl:w-[560px] h-[580px] xl:h-[640px]">

          <!-- Glow detrás -->
          <div class="absolute inset-0 -z-10 blur-3xl opacity-60"
               style="background: radial-gradient(ellipse at 65% 35%, rgba(0,229,255,0.12), transparent 65%);"></div>

          <!-- TOP-LEFT: Tartas -->
          <div class="absolute top-0 left-0 w-[238px] xl:w-[268px] h-[278px] xl:h-[308px] rounded-2xl overflow-hidden"
               style="transform: rotate(-2deg);
                      box-shadow: 0 24px 48px rgba(0,0,0,0.7), 0 0 0 1px rgba(224,64,251,0.2);">
            <img
              src="/images/tartas.jpg"
              alt="Tartas Delicias Cosas Ricas"
              class="object-cover w-full h-full hover:scale-[1.04] transition-transform duration-700 ease-out"
              loading="eager"
            />
            <div class="absolute bottom-0 inset-x-0 h-14"
                 style="background: linear-gradient(to top, rgba(7,7,16,0.6), transparent);"></div>
          </div>

          <!-- TOP-RIGHT: Pizza -->
          <div class="absolute top-0 right-0 w-[238px] xl:w-[268px] h-[278px] xl:h-[308px] rounded-2xl overflow-hidden"
               style="transform: rotate(2deg);
                      box-shadow: 0 24px 48px rgba(0,0,0,0.7), 0 0 0 1px rgba(255,255,255,0.07);">
            <img
              src="/images/pizzacuatroquesos.jpg"
              alt="Pizza Cuatro Quesos Café Doncar"
              class="object-cover w-full h-full hover:scale-[1.04] transition-transform duration-700 ease-out"
              fetchpriority="high"
            />
            <div class="absolute bottom-0 inset-x-0 h-14"
                 style="background: linear-gradient(to top, rgba(7,7,16,0.6), transparent);"></div>
          </div>

          <!-- BOTTOM-LEFT: Burger -->
          <div class="absolute bottom-0 left-0 w-[238px] xl:w-[268px] h-[278px] xl:h-[308px] rounded-2xl overflow-hidden"
               style="transform: rotate(1.5deg);
                      box-shadow: 0 24px 48px rgba(0,0,0,0.7), 0 0 0 1px rgba(180,79,255,0.25);">
            <img
              src="/images/burgerclásica.jpg"
              alt="Hamburguesa Café Doncar"
              class="object-cover w-full h-full hover:scale-[1.04] transition-transform duration-700"
              loading="eager"
            />
            <div class="absolute bottom-0 inset-x-0 h-14"
                 style="background: linear-gradient(to top, rgba(7,7,16,0.6), transparent);"></div>
          </div>

          <!-- BOTTOM-RIGHT: Brownie Oreo -->
          <div class="absolute bottom-0 right-0 w-[238px] xl:w-[268px] h-[278px] xl:h-[308px] rounded-2xl overflow-hidden"
               style="transform: rotate(-1.5deg);
                      box-shadow: 0 24px 48px rgba(0,0,0,0.7), 0 0 0 1px rgba(0,229,255,0.2);">
            <img
              src="/images/brownieOreo2.jpeg"
              alt="Brownie Oreo Delicias"
              class="object-cover w-full h-full hover:scale-[1.04] transition-transform duration-700"
              loading="eager"
            />
            <div class="absolute bottom-0 inset-x-0 h-14"
                 style="background: linear-gradient(to top, rgba(7,7,16,0.6), transparent);"></div>
          </div>

          <!-- Logo flotando sobre la pizza (top-right) -->
          <div class="absolute top-[-16px] right-[-12px] z-20 animate-fade-in-up pointer-events-none">
            <img
              src="/images/logo1comb.svg"
              alt="Café Doncar Delicias"
              class="w-[170px] xl:w-[200px] h-auto"
              style="filter: drop-shadow(0 0 20px rgba(0,229,255,0.45)) drop-shadow(0 0 40px rgba(180,79,255,0.25));"
            />
          </div>

          <!-- Badge flotante -->
          <div class="absolute bottom-[295px] xl:bottom-[325px] left-1/2 -translate-x-1/2 z-30
                      inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full text-white text-[11px] font-bold whitespace-nowrap"
               style="background: rgba(7,7,16,0.9);
                      border: 1px solid rgba(0,229,255,0.35);
                      backdrop-filter: blur(12px);
                      box-shadow: 0 4px 20px rgba(0,0,0,0.5);">
            <span style="color:#00E5FF">✦</span> 100% Artesanal
          </div>

        </div>
      </div>

    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-5 left-1/2 -translate-x-1/2 z-10 flex flex-col items-center gap-1.5">
    <div class="w-1 h-1 rounded-full" style="background: rgba(0,229,255,0.4);"></div>
    <div class="w-px h-7" style="background: linear-gradient(to bottom, rgba(0,229,255,0.4), transparent);"></div>
  </div>

</section>
