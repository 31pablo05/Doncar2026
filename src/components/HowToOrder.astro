<div class="mb-12">
  <div class="text-center mb-8">
    <h3 class="font-syne font-bold text-2xl text-white mb-2">¿Cómo hacer tu pedido?</h3>
    <div class="w-16 h-1 mx-auto rounded-full" style="background: linear-gradient(90deg, #00E5FF, #B44FFF);"></div>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 max-w-3xl mx-auto">
    {[
      { n: '1', icon: '🛒', title: 'Elegí tus favoritos', desc: 'Navegá el menú y agregá productos al carrito' },
      { n: '2', icon: '✅', title: 'Revisá tu pedido', desc: 'Verificá cantidades y completá tus datos' },
      { n: '3', icon: '💬', title: 'Enviá por WhatsApp', desc: 'Tu pedido se arma solo y se envía directo al local' },
    ].map(step => (
      <div class="relative rounded-2xl p-6 border text-center transition-all duration-300 hover:scale-105"
           style="background: rgba(0,229,255,0.03); border: 1px solid rgba(0,229,255,0.18); box-shadow: 0 0 15px rgba(0,229,255,0.06);">
        <div class="absolute -top-3 -left-3 w-8 h-8 rounded-full flex items-center justify-center font-black text-sm shadow-lg"
             style="background: linear-gradient(135deg, #00E5FF, #B44FFF); color: #070710;">
          {step.n}
        </div>
        <div class="text-4xl mb-3">{step.icon}</div>
        <h4 class="font-syne font-bold text-white mb-2">{step.title}</h4>
        <p class="text-white/50 text-sm">{step.desc}</p>
      </div>
    ))}
  </div>
</div>
