---
import ClockWidget from './ClockWidget';
---

<section class="py-20 px-4" style="background: #070710;">
  <div class="max-w-4xl mx-auto text-center">
    <h2 class="font-syne font-black text-2xl sm:text-3xl md:text-4xl lg:text-5xl text-white mb-4">
      Horarios de <span style="color: #00E5FF;">Atención</span>
    </h2>
    <div class="w-20 h-1 mx-auto rounded-full mb-12" style="background: linear-gradient(90deg, #00E5FF, #B44FFF);"></div>

    <!-- Reloj en vivo (React island mínimo) -->
    <ClockWidget client:idle />

    <!-- Info de horarios (estático) -->
    <div class="mt-10 max-w-xl mx-auto space-y-4">

      <!-- Lunes -->
      <div class="p-5 rounded-2xl border flex items-center justify-between gap-4" style="background: rgba(0,229,255,0.06); border-color: rgba(0,229,255,0.2);">
        <div class="font-syne font-bold text-white text-base w-36 shrink-0" style="color: #00E5FF;">Lunes</div>
        <div class="text-white/70 text-sm text-right">
          <div>19:30 — 00:00 hs</div>
        </div>
      </div>

      <!-- Mar · Mier · Jue -->
      <div class="p-5 rounded-2xl border flex items-center justify-between gap-4" style="background: rgba(0,229,255,0.06); border-color: rgba(0,229,255,0.2);">
        <div class="font-syne font-bold text-white text-base w-36 shrink-0" style="color: #00E5FF;">Mar · Mier · Jue</div>
        <div class="text-white/70 text-sm text-right space-y-1">
          <div>11:30 — 14:30 hs</div>
          <div>19:30 — 00:00 hs</div>
        </div>
      </div>

      <!-- Vier · Sab · Dom -->
      <div class="p-5 rounded-2xl border flex items-center justify-between gap-4" style="background: rgba(0,229,255,0.06); border-color: rgba(0,229,255,0.2);">
        <div class="font-syne font-bold text-white text-base w-36 shrink-0" style="color: #00E5FF;">Vier · Sab · Dom</div>
        <div class="text-white/70 text-sm text-right space-y-1">
          <div>11:30 — 14:30 hs</div>
          <div>19:30 — 00:30 hs</div>
        </div>
      </div>

      <!-- Delivery -->
      <div class="p-5 rounded-2xl border text-center" style="background: rgba(180,79,255,0.06); border-color: rgba(180,79,255,0.2);">
        <div class="text-3xl mb-2">🚀</div>
        <div class="font-syne font-bold text-white text-lg">Delivery & Retiro</div>
        <div class="text-white/50 text-sm mt-1">Pellegrini 1624, Trelew</div>
      </div>

    </div>
  </div>
</section>
