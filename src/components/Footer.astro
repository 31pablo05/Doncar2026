---
import { siteConfig } from '../data/siteConfig';
---

<footer class="py-10 md:py-16 px-4 border-t" style="background: #070710; border-color: rgba(0,229,255,0.08);">
  <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12">

    <!-- Marca -->
    <div>
      <div class="flex items-center gap-3 mb-4">
        <img
          src="/images/logo1comb.svg"
          alt="Café Doncar Delicias"
          class="h-28 w-auto"
          style="filter: drop-shadow(0 0 10px rgba(0,229,255,0.3));"
        />
      </div>
      <p class="text-white/50 text-sm leading-relaxed">
        Pizza & Food · Cosas Ricas<br />
        Hamburguesas artesanales y postres en Trelew. Elaboración 100% casera desde 2020.
      </p>
      <div class="flex gap-3 mt-4">
        <a href={siteConfig.instagram} target="_blank"
           class="p-2 rounded-lg transition-all hover:scale-110"
           style="background: rgba(255,255,255,0.05);">📸</a>
        <a href={siteConfig.facebook} target="_blank"
           class="p-2 rounded-lg transition-all hover:scale-110"
           style="background: rgba(255,255,255,0.05);">👍</a>
      </div>
    </div>

    <!-- Contacto -->
    <div>
      <h4 class="font-syne font-bold text-white mb-4">Contacto</h4>
      <ul class="space-y-3 text-white/50 text-sm">
        <li>📍 Pellegrini 1624, Trelew, Chubut</li>
        <li>📞 <a href="tel:2804518716" class="transition-colors" style="color: rgba(0,229,255,0.7);" onmouseover="this.style.color='#00E5FF'" onmouseout="this.style.color='rgba(0,229,255,0.7)'">280 4518716</a></li>
        <li>🎂 Pedidos especiales Delicias: <a href="tel:2804717703" class="transition-colors" style="color: rgba(0,229,255,0.7);" onmouseover="this.style.color='#00E5FF'" onmouseout="this.style.color='rgba(0,229,255,0.7)'">280 471-7703</a></li>
        <li>📸 <a href="{siteConfig.instagram}" target="_blank" class="transition-colors" style="color: rgba(0,229,255,0.7);" onmouseover="this.style.color='#00E5FF'" onmouseout="this.style.color='rgba(0,229,255,0.7)'">@cafedoncar</a></li>
        <li>🕕 Lun-Dom: 18:00 — 00:30 hs</li>
      </ul>
    </div>

    <!-- WhatsApp CTA -->
    <div>
      <h4 class="font-syne font-bold text-white mb-4">¿Listo para pedir?</h4>
      <p class="text-white/50 text-sm mb-4">Hacé tu pedido directo por WhatsApp en segundos.</p>
      <a href={`https://wa.me/${siteConfig.whatsapp}?text=${encodeURIComponent('¡Hola! Quiero hacer un pedido 🍔')}`}
         target="_blank"
         class="inline-flex items-center gap-2 px-6 py-3 rounded-xl font-bold text-white transition-all hover:scale-105"
         style="background: linear-gradient(135deg, #25D366, #128C7E);">
        💬 Pedir por WhatsApp
      </a>
    </div>
  </div>

  <div class="max-w-6xl mx-auto mt-12 pt-6 border-t flex flex-col sm:flex-row justify-between items-center gap-2"
       style="border-color: rgba(0,229,255,0.08);">
    <p class="text-white/30 text-sm">© {new Date().getFullYear()} Café Doncar. Todos los derechos reservados.</p>
    <p class="text-white/20 text-xs">Desarrollado por Pablo Proboste</p>
  </div>
</footer>
