---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import HeroSection from '../components/HeroSection.astro';
import DeliveryBanner from '../components/DeliveryBanner.astro';
import HowToOrder from '../components/HowToOrder.astro';
import MenuSection from '../components/MenuSection';
import AboutSection from '../components/AboutSection.astro';
import BusinessHours from '../components/BusinessHours.astro';
import ReviewsSection from '../components/ReviewsSection.astro';
import Footer from '../components/Footer.astro';
import { menuItems } from '../data/menuItems';
import { categories } from '../data/categories';
---

<Layout>
  <Header />
  <main>
    <section id="inicio">
      <HeroSection />
    </section>

    <DeliveryBanner />

    <section id="menu" class="py-12 px-4 max-w-7xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="font-syne text-4xl md:text-5xl font-black mb-4" style="color: #FFB800;">
          Nuestro Menú
        </h2>
        <p class="text-white/70 text-lg max-w-2xl mx-auto">
          Descubrí nuestras hamburguesas, pizzas artesanales y mucho más
        </p>
      </div>
      <HowToOrder />
      <MenuSection client:visible menuItems={menuItems} categories={categories} />
    </section>

    <section id="nosotros">
      <AboutSection />
    </section>

    <section id="horarios">
      <BusinessHours />
    </section>

    <section id="resenas">
      <ReviewsSection />
    </section>
  </main>
  <Footer />
</Layout>
